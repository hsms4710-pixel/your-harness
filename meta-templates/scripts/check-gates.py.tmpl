            {{/if}}
        ],
        "checks": [
            "需求已澄清",
            "歧义已解决",
            {{#if has_security_surface}}
            "安全影响已评估",
            {{/if}}
            {{#if has_performance_surface}}
            "性能影响已评估",
            {{/if}}
        ],
        "required": {{is_clarification_required}}
    },
    "G1_PRD": {
        "stage": "PRD 完成",
        "description": "PRD 完成后",
        "artifacts": [
            {{#if has_spec_structure}}
            "docs/spec/<feature>/analyze/01-prd.md",
            {{else}}
            "docs/<feature>/prd.md",
            {{/if}}
        ],
        "checks": [
            "PRD 包含完整的 User Stories",
            "Acceptance Criteria 可测",
            {{#if has_api_change}}
            "API 契约已定义",
            {{/if}}
        ],
        "required": {{is_prd_required}}
    },
    "G2_TASKS": {
        "stage": "任务拆解",
        "description": "任务拆解后",
        "artifacts": [
            {{#if has_spec_structure}}
            "docs/spec/<feature>/design/01-tasks.md",
            {{else}}
            "docs/<feature>/tasks.md",
            {{/if}}
        ],
        "checks": [
            "任务粒度合理",
            "依赖关系明确",
            {{#if has_multi_repo}}
            "跨仓库依赖已识别",
            {{/if}}
        ],
        "required": {{is_tasks_required}}
    },
    "G3_SLICE": {
        "stage": "代码切片",
        "description": "每个代码切片后",
        "artifacts": [
            "代码变更",
            {{#if has_spec_structure}}
            "docs/spec/<feature>/develop/3X-*.md",
            {{else}}
            "docs/<feature>/slice-*.md",
            {{/if}}
        ],
        "checks": [
            "测试通过",
            "代码审查通过",
            "切片实现纪要已写",
        ],
        "required": True
    },
    "G4_VERIFY": {
        "stage": "验证完成",
        "description": "验证完成后",
        "artifacts": [
            {{#if has_spec_structure}}
            "docs/spec/<feature>/test/02-test-report.md",
            {{else}}
            "docs/<feature>/test-report.md",
            {{/if}}
        ],
        "checks": [
            "覆盖率达标",
