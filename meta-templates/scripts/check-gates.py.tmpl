#!/usr/bin/env python3
"""
闸门状态检查脚本
项目: {{project_name}}
检查特定闸门是否可以通过

使用方法:
    python check-gates.py can-advance --feature <name> --gate <gate-id>
    python check-gates.py status --feature <name>
    python check-gates.py approve --feature <name> --gate <gate-id>
"""
import json
import sys
from pathlib import Path
from datetime import datetime

# ============================================================
# 项目特定配置
# ============================================================

PROJECT_NAME = "{{project_name}}"

# 闸门定义 - 根据项目特征动态生成
GATES = {
