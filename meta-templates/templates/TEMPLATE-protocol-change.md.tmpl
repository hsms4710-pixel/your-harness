echo "请提供以下信息："
echo "- MR 标题:"
read mr_title
echo "- MR 描述:"
read mr_description
echo "- 目标分支 (默认 main):"
read target_branch

# mcp_call tool="mcp__gongfeng-woa__create_merge_request" \
#   arguments='{"project_id": "{{project_path}}", "title": "'$mr_title'", "description": "'$mr_description'", "source_branch": "feature/{{feature_name}}", "target_branch": "${target_branch:-main}"}'
{{else}}
```bash
# 手动创建 MR
git push origin feature/{{feature_name}}
echo "请手动创建 MR: https://git.example.com/{{project_path}}/-/merge_requests/new"
{{/if}}
```

**Expected**
- MR 创建成功
- MR 描述完整
- 审查者已指定

---

