### 3.2 Prompt 管理实现

**Input**
- Prompt 设计

**Process**
1. 实现 Prompt 模板类
2. 实现变量替换
3. 实现版本管理
4. 添加缓存（可选）

**Run**
```bash
{{#if has_python}}
# 创建 Prompt 管理器
touch llm/prompt_manager.py

# 实现管理器
cat > llm/prompt_manager.py << 'EOF'
import json
import hashlib
from typing import Dict, Any
from pathlib import Path
from dataclasses import dataclass

@dataclass
class PromptTemplate:
    """Prompt 模板"""
    name: str
    template: str
    variables: list[str]
    version: str
    
class PromptManager:
    """Prompt 管理器"""
    
    def __init__(self, templates_dir: str = "prompts"):
        self.templates_dir = Path(templates_dir)
        self._cache: Dict[str, PromptTemplate] = {}
        
    def load_template(self, name: str) -> PromptTemplate:
        """加载模板"""
        if name in self._cache:
            return self._cache[name]
            
        template_path = self.templates_dir / f"{name}.j2"
        meta_path = self.templates_dir / f"{name}.json"
        
        with open(template_path) as f:
            template = f.read()
            
        with open(meta_path) as f:
            meta = json.load(f)
            
        prompt = PromptTemplate(
            name=name,
            template=template,
            variables=meta["variables"],
            version=meta["version"]
        )
        
        self._cache[name] = prompt
        return prompt
        
    def render(self, name: str, variables: Dict[str, Any]) -> str:
        """渲染 Prompt"""
        from jinja2 import Template
        
        template = self.load_template(name)
        j2_template = Template(template.template)
        return j2_template.render(**variables)
        
    def get_hash(self, name: str, variables: Dict[str, Any]) -> str:
        """获取 Prompt 哈希"""
        rendered = self.render(name, variables)
        return hashlib.md5(rendered.encode()).hexdigest()
EOF
{{else_if has_typescript}}
# 创建 Prompt 管理器
touch src/llm/promptManager.ts

# 实现管理器
cat > src/llm/promptManager.ts << 'EOF'
import * as fs from 'fs';
import * as path from 'path';

interface PromptMeta {
  name: string;
  variables: string[];
  version: string;
}

interface PromptTemplate {
  name: string;
  template: string;
  variables: string[];
  version: string;
}

class PromptManager {
  private templatesDir: string;
  private cache: Map<string, PromptTemplate> = new Map();
  
  constructor(templatesDir: string = 'prompts') {
    this.templatesDir = templatesDir;
  }
  
  loadTemplate(name: string): PromptTemplate {
    if (this.cache.has(name)) {
      return this.cache.get(name)!;
    }
    
    const templatePath = path.join(this.templatesDir, `${name}.j2`);
    const metaPath = path.join(this.templatesDir, `${name}.json`);
    
    const template = fs.readFileSync(templatePath, 'utf-8');
    const meta = JSON.parse(fs.readFileSync(metaPath, 'utf-8')) as PromptMeta;
    
    const prompt: PromptTemplate = {
      name,
      template,
      variables: meta.variables,
      version: meta.version
    };
    
    this.cache.set(name, prompt);
    return prompt;
  }
  
  render(name: string, variables: Record<string, any>): string {
    const template = this.loadTemplate(name);
    return template.template.replace(/\{\{(.+?)\}\}/g, (match, key) => {
      return variables[key.trim()] ?? match;
    });
  }
}
EOF
{{/if}}
