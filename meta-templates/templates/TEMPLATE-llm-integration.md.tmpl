### 3.3 RAG 实现（如需要）

**Input**
- RAG 设计

**Process**
1. 实现 Embedding 模型
2. 实现向量存储
3. 实现检索逻辑
4. 实现上下文构建

**Run**
```bash
{{#if has_python}}
# 创建 RAG 模块
touch llm/rag.py

# 实现 RAG
cat > llm/rag.py << 'EOF'
from typing import List, Dict, Any
from dataclasses import dataclass

@dataclass
class SearchResult:
    """搜索结果"""
    content: str
    score: float
    metadata: Dict[str, Any]
    
class VectorStore:
    """向量存储基类"""
    
    @abstractmethod
    def add(self, documents: List[dict]) -> None:
        """添加文档"""
        pass
    
    @abstractmethod
    def search(self, query: str, top_k: int = 5) -> List[SearchResult]:
        """搜索"""
        pass
    
    @abstractmethod
    def delete(self, ids: List[str]) -> None:
        """删除"""
        pass

class RAGPipeline:
    """RAG 管道"""
    
    def __init__(self, embedding_model, vector_store: VectorStore):
        self.embedding = embedding_model
        self.vector_store = vector_store
        
    def index_document(self, text: str, metadata: Dict[str, Any] = None):
        """索引文档"""
        embedding = self.embedding.encode(text)
        self.vector_store.add([{
            "content": text,
            "embedding": embedding,
            "metadata": metadata or {}
        }])
        
    def retrieve(self, query: str, top_k: int = 5) -> List[SearchResult]:
        """检索"""
        query_embedding = self.embedding.encode(query)
        return self.vector_store.search(query_embedding, top_k)
        
    def build_context(self, query: str, top_k: int = 5) -> str:
        """构建上下文"""
        results = self.retrieve(query, top_k)
        return "\n\n".join([r.content for r in results])
EOF
{{else_if has_typescript}}
# 创建 RAG 模块
touch src/llm/rag.ts

# 实现 RAG
cat > src/llm/rag.ts << 'EOF'
interface SearchResult {
  content: string;
  score: number;
  metadata: Record<string, any>;
}

interface VectorStore {
  add(documents: Array<{content: string; metadata?: Record<string, any>}>): void;
  search(query: string, topK?: number): SearchResult[];
  delete(ids: string[]): void;
}

class RAGPipeline {
  private embedding: EmbeddingModel;
  private vectorStore: VectorStore;
  
  constructor(embedding: EmbeddingModel, vectorStore: VectorStore) {
    this.embedding = embedding;
    this.vectorStore = vectorStore;
  }
  
  indexDocument(text: string, metadata?: Record<string, any>): void {
    const embedding = this.embedding.encode(text);
    this.vectorStore.add([{content: text, embedding, metadata}]);
  }
  
  retrieve(query: string, topK: number = 5): SearchResult[] {
    const queryEmbedding = this.embedding.encode(query);
    return this.vectorStore.search(queryEmbedding, topK);
  }
  
  buildContext(query: string, topK: number = 5): string {
    const results = this.retrieve(query, topK);
    return results.map(r => r.content).join('\n\n');
  }
}
EOF
{{/if}}
